@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@using app.Resources
@using Microsoft.Extensions.Localization

<footer class="bg-dark-purple text-white/80 mt-2">
    <div class="container mx-auto px-6 lg:px-8 py-16 lg:py-20">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">
            <!-- Brand -->
            <div class="lg:col-span-4">
                <a href="/" data-enhance-nav="false" class="inline-flex items-center" aria-label="Home">
                    <img src="/assets/brand/logo.png" alt=".NET Cameroon logo" class="w-14">
                </a>
                <p class="text-white/60 text-sm leading-relaxed mt-5 max-w-xs">@L["Footer_Line"]</p>
            </div>

            <!-- Navigate -->
            <nav class="lg:col-span-2">
                <h2 class="eyebrow text-white/40">@L["Footer_Navigation"]</h2>
                <ul class="mt-5 space-y-2.5 text-sm">
                    <li><a data-enhance-nav="false" href="/" class="text-white/70 hover:text-white transition-colors" aria-label="Home">@L["Footer_Home"]</a></li>
                    <li><a data-enhance-nav="false" href="/events" class="text-white/70 hover:text-white transition-colors" aria-label="Events">@L["Footer_Events"]</a></li>
                    <li><a data-enhance-nav="false" href="/about" class="text-white/70 hover:text-white transition-colors" aria-label="About">@L["Footer_About"]</a></li>
                </ul>
            </nav>

            <!-- Contact -->
            <div class="lg:col-span-3">
                <h2 class="eyebrow text-white/40">@L["Footer_Contact"]</h2>
                <ul class="mt-5 space-y-2.5 text-sm">
                    <li class="text-white/70">@L["Footer_Location"]</li>
                    <li>
                        <a data-enhance-nav="false" href="mailto:@L["Footer_Email"]" class="text-white/70 hover:text-white transition-colors" aria-label="Email dotnetcameroon">@L["Footer_Email"]</a>
                    </li>
                    <li class="text-white/70">@L["Footer_Phone"]</li>
                </ul>
            </div>

            <!-- Social -->
            <div class="lg:col-span-3">
                <h2 class="eyebrow text-white/40">@L["Footer_Social"]</h2>
                <ul class="mt-5 flex flex-wrap gap-2">
                    <li>
                        <a data-enhance-nav="false" href="https://discord.gg/npkCMRgqdm" target="_blank"
                           class="inline-flex items-center justify-center size-10 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white/70 hover:text-white transition-colors"
                           aria-label="Join Discord">
                            <i class="ph-fill ph-discord-logo text-lg"></i>
                        </a>
                    </li>
                    <li>
                        <a data-enhance-nav="false" href="https://chat.whatsapp.com/KlBkiJX85Y8KFS28tIm1UU" target="_blank"
                           class="inline-flex items-center justify-center size-10 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white/70 hover:text-white transition-colors"
                           aria-label="Join WhatsApp">
                            <i class="ph-fill ph-whatsapp-logo text-lg"></i>
                        </a>
                    </li>
                    <li>
                        <a data-enhance-nav="false" href="https://www.linkedin.com/company/dotnetcameroon" target="_blank"
                           class="inline-flex items-center justify-center size-10 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white/70 hover:text-white transition-colors"
                           aria-label="LinkedIn">
                            <i class="ph-fill ph-linkedin-logo text-lg"></i>
                        </a>
                    </li>
                    <li>
                        <a data-enhance-nav="false" href="https://t.me/+cjXkPqigrZNkNDE0" target="_blank"
                           class="inline-flex items-center justify-center size-10 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white/70 hover:text-white transition-colors"
                           aria-label="Telegram">
                            <i class="ph-fill ph-telegram-logo text-lg"></i>
                        </a>
                    </li>
                    <li>
                        <a data-enhance-nav="false" href="https://github.com/dotnetcameroon" target="_blank"
                           class="inline-flex items-center justify-center size-10 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white/70 hover:text-white transition-colors"
                           aria-label="GitHub">
                            <i class="ph-fill ph-github-logo text-lg"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="mt-16 pt-8 border-t border-white/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <p class="text-white/50 text-xs">@L["Footer_Copyright"] &copy; .NET Cameroon @Year</p>
            <p class="text-white/50 text-xs">Designed by <a href="https://yop.agency" target="_blank" class="text-white/70 hover:text-white transition-colors font-medium">Lagence YOP</a></p>
        </div>
    </div>
</footer>

@code {
    private Microsoft.Extensions.Localization.IStringLocalizer? _sharedLocalizer;
    private Microsoft.Extensions.Localization.IStringLocalizer L => _sharedLocalizer ??= LocalizerFactory.Create("SharedResources", "app");

    public int Year => DateTime.Now.Year;
}
