@page "/contact"
@using Microsoft.Extensions.Localization
@attribute [StreamRendering]
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory

<PageTitle>Contact Us - .NET Cameroon</PageTitle>
<HeadContent>
    <meta name="description" content="Get in touch with .NET Cameroon community. We're here to help you connect, learn, and grow with us.">
    <meta property="og:title" content="Contact Us - .NET Cameroon">
    <meta property="og:description" content="Get in touch with .NET Cameroon community. Reach out for partnerships, speaking opportunities, or any questions.">
    <meta property="og:image" content="https://dotnet.cm/assets/brand/logo.png">
    <meta property="og:url" content="https://dotnet.cm/contact">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Contact Us - .NET Cameroon">
    <meta name="twitter:description" content="Get in touch with .NET Cameroon community.">
</HeadContent>

<div>
    <NavBar />

    <!-- Page header -->
    <section class="bg-dark-purple relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-dark-purple via-secondary/30 to-dark-purple"></div>
        <div class="relative container mx-auto px-6 lg:px-8 py-20 lg:py-28">
            <div class="max-w-3xl">
                <span class="eyebrow text-white/60">Contact</span>
                <h1 class="text-white heading font-bold text-4xl sm:text-5xl lg:text-6xl leading-[1.05] tracking-tight mt-6">
                    Let's talk.
                </h1>
                <p class="text-white/75 text-base lg:text-lg leading-relaxed max-w-2xl mt-6">
                    Questions, partnerships, speaking, sponsorship — drop us a line. We typically reply within a couple of days.
                </p>
            </div>
        </div>
    </section>

    <!-- Direct contact strip -->
    <section class="bg-white border-b border-gray-100">
        <div class="container mx-auto px-6 lg:px-8 py-10 lg:py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-200/70 border border-gray-200/70 rounded-xl overflow-hidden">
                <div class="bg-white p-6">
                    <div class="inline-flex items-center justify-center size-10 rounded-lg bg-primary/10 text-primary">
                        <i class="ph ph-envelope text-lg"></i>
                    </div>
                    <h3 class="heading font-semibold text-sm text-dark-purple mt-4">Email</h3>
                    <a href="mailto:contact@dotnet.cm" class="text-secondary hover:text-secondary-accentuation transition-colors text-sm mt-1 inline-block">
                        contact@dotnet.cm
                    </a>
                </div>
                <div class="bg-white p-6">
                    <div class="inline-flex items-center justify-center size-10 rounded-lg bg-secondary/10 text-secondary">
                        <i class="ph ph-map-pin text-lg"></i>
                    </div>
                    <h3 class="heading font-semibold text-sm text-dark-purple mt-4">Location</h3>
                    <p class="text-gray-600 text-sm mt-1">Douala & Yaoundé, Cameroon</p>
                </div>
                <div class="bg-white p-6">
                    <div class="inline-flex items-center justify-center size-10 rounded-lg bg-tertiary/10 text-tertiary">
                        <i class="ph ph-users-three text-lg"></i>
                    </div>
                    <h3 class="heading font-semibold text-sm text-dark-purple mt-4">Community</h3>
                    <div class="flex items-center gap-2 mt-2">
                        <a href="https://discord.gg/npkCMRgqdm" target="_blank"
                           class="inline-flex items-center justify-center size-8 rounded-md bg-gray-50 hover:bg-gray-100 border border-gray-200/70 text-gray-600 hover:text-dark-purple transition-colors"
                           aria-label="Discord">
                            <i class="ph-fill ph-discord-logo text-sm"></i>
                        </a>
                        <a href="https://www.linkedin.com/company/dotnetcameroon" target="_blank"
                           class="inline-flex items-center justify-center size-8 rounded-md bg-gray-50 hover:bg-gray-100 border border-gray-200/70 text-gray-600 hover:text-dark-purple transition-colors"
                           aria-label="LinkedIn">
                            <i class="ph-fill ph-linkedin-logo text-sm"></i>
                        </a>
                        <a href="https://github.com/dotnetcameroon" target="_blank"
                           class="inline-flex items-center justify-center size-8 rounded-md bg-gray-50 hover:bg-gray-100 border border-gray-200/70 text-gray-600 hover:text-dark-purple transition-colors"
                           aria-label="GitHub">
                            <i class="ph-fill ph-github-logo text-sm"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Form + Why contact us -->
    <section class="bg-white">
        <div class="container mx-auto px-6 lg:px-8 py-20 lg:py-24">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
                <!-- Form -->
                <div class="lg:col-span-3">
                    <span class="eyebrow text-primary">Message us</span>
                    <h2 class="heading heading-1 mt-4">Send a message</h2>
                    <p class="text-gray-600 leading-relaxed mt-4">
                        Fill in the form and we'll get back to you shortly.
                    </p>

                    @if (_submitted)
                    {
                        <div class="mt-10 rounded-xl border border-gray-200/70 bg-gray-50/50 p-8 text-center">
                            <div class="inline-flex items-center justify-center size-12 rounded-full bg-primary/10 text-primary">
                                <i class="ph ph-check text-2xl"></i>
                            </div>
                            <h3 class="heading font-semibold text-lg text-dark-purple mt-5">Message sent</h3>
                            <p class="text-gray-600 text-sm leading-relaxed mt-3 max-w-md mx-auto">
                                Thanks for reaching out — we'll be in touch soon.
                            </p>
                            <button @onclick="ResetForm" class="btn btn-outline mt-6">
                                Send another
                            </button>
                        </div>
                    }
                    else
                    {
                        <form @onsubmit="HandleSubmit" class="mt-10 space-y-5">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div>
                                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">Full name <span class="text-red-500">*</span></label>
                                    <input type="text" id="name" @bind="_formData.Name" required
                                           class="w-full px-3.5 py-2.5 text-sm bg-gray-50/70 border border-gray-200 rounded-lg focus:outline-none focus:border-secondary focus:bg-white focus:ring-2 focus:ring-secondary/15 transition-colors"
                                           placeholder="Your name" />
                                </div>
                                <div>
                                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email <span class="text-red-500">*</span></label>
                                    <input type="email" id="email" @bind="_formData.Email" required
                                           class="w-full px-3.5 py-2.5 text-sm bg-gray-50/70 border border-gray-200 rounded-lg focus:outline-none focus:border-secondary focus:bg-white focus:ring-2 focus:ring-secondary/15 transition-colors"
                                           placeholder="you@example.com" />
                                </div>
                            </div>

                            <div>
                                <label for="subject" class="block text-sm font-medium text-gray-700 mb-1.5">Subject <span class="text-red-500">*</span></label>
                                <select id="subject" @bind="_formData.Subject" required
                                        class="w-full px-3.5 py-2.5 text-sm bg-gray-50/70 border border-gray-200 rounded-lg focus:outline-none focus:border-secondary focus:bg-white focus:ring-2 focus:ring-secondary/15 transition-colors">
                                    <option value="">Select a subject</option>
                                    <option value="general">General inquiry</option>
                                    <option value="partnership">Partnership</option>
                                    <option value="speaking">Speaking opportunity</option>
                                    <option value="sponsorship">Sponsorship</option>
                                    <option value="feedback">Feedback</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>

                            <div>
                                <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-red-500">*</span></label>
                                <textarea id="message" @bind="_formData.Message" required rows="6"
                                          class="w-full px-3.5 py-2.5 text-sm bg-gray-50/70 border border-gray-200 rounded-lg focus:outline-none focus:border-secondary focus:bg-white focus:ring-2 focus:ring-secondary/15 transition-colors"
                                          placeholder="Tell us how we can help..."></textarea>
                            </div>

                            @if (!string.IsNullOrEmpty(_errorMessage))
                            {
                                <div class="flex items-start gap-2 p-3 rounded-lg bg-red-50/70 border border-red-200 text-red-700 text-sm">
                                    <i class="ph ph-warning-circle text-base shrink-0 mt-0.5"></i>
                                    <span>@_errorMessage</span>
                                </div>
                            }

                            <button type="submit" class="btn btn-primary inline-flex items-center justify-center gap-2" disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <i class="ph ph-spinner-gap text-base animate-spin"></i>
                                    <span>Sending…</span>
                                }
                                else
                                {
                                    <i class="ph ph-paper-plane-tilt text-base"></i>
                                    <span>Send message</span>
                                }
                            </button>
                        </form>
                    }
                </div>

                <!-- Why contact us -->
                <aside class="lg:col-span-2">
                    <span class="eyebrow text-secondary">Reasons to reach out</span>
                    <h2 class="heading heading-2 mt-3">Why contact us</h2>

                    <div class="mt-8 space-y-6">
                        <div class="flex gap-4">
                            <div class="shrink-0 inline-flex items-center justify-center size-10 rounded-lg bg-primary/10 text-primary">
                                <i class="ph-duotone ph-handshake text-lg"></i>
                            </div>
                            <div>
                                <h3 class="heading font-semibold text-sm text-dark-purple">Partnership</h3>
                                <p class="text-gray-600 text-sm leading-relaxed mt-1.5">
                                    Let's explore how we can grow the .NET community together.
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="shrink-0 inline-flex items-center justify-center size-10 rounded-lg bg-secondary/10 text-secondary">
                                <i class="ph-duotone ph-microphone-stage text-lg"></i>
                            </div>
                            <div>
                                <h3 class="heading font-semibold text-sm text-dark-purple">Speaking</h3>
                                <p class="text-gray-600 text-sm leading-relaxed mt-1.5">
                                    Share your expertise at our meetups and conferences.
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="shrink-0 inline-flex items-center justify-center size-10 rounded-lg bg-tertiary/10 text-tertiary">
                                <i class="ph-duotone ph-star text-lg"></i>
                            </div>
                            <div>
                                <h3 class="heading font-semibold text-sm text-dark-purple">Sponsorship</h3>
                                <p class="text-gray-600 text-sm leading-relaxed mt-1.5">
                                    Support our mission and reach our developer audience.
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="shrink-0 inline-flex items-center justify-center size-10 rounded-lg bg-primary/10 text-primary">
                                <i class="ph-duotone ph-question text-lg"></i>
                            </div>
                            <div>
                                <h3 class="heading font-semibold text-sm text-dark-purple">General questions</h3>
                                <p class="text-gray-600 text-sm leading-relaxed mt-1.5">
                                    Anything about events, membership, or activities.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Community channels -->
                    <div class="mt-10 rounded-xl border border-gray-200/70 overflow-hidden bg-white">
                        <div class="px-5 py-4 border-b border-gray-100">
                            <h3 class="heading font-semibold text-sm text-dark-purple">Join our community</h3>
                        </div>
                        <div class="divide-y divide-gray-100">
                            <a href="https://discord.gg/npkCMRgqdm" target="_blank"
                               class="flex items-center gap-3 p-4 hover:bg-gray-50/60 transition-colors group">
                                <span class="inline-flex items-center justify-center size-9 rounded-lg bg-gray-100 text-gray-700">
                                    <i class="ph-fill ph-discord-logo text-base"></i>
                                </span>
                                <span class="flex-1 text-sm font-medium text-dark-purple">Discord</span>
                                <i class="ph ph-arrow-up-right text-gray-300 group-hover:text-dark-purple transition-colors text-sm"></i>
                            </a>
                            <a href="https://chat.whatsapp.com/KlBkiJX85Y8KFS28tIm1UU" target="_blank"
                               class="flex items-center gap-3 p-4 hover:bg-gray-50/60 transition-colors group">
                                <span class="inline-flex items-center justify-center size-9 rounded-lg bg-gray-100 text-gray-700">
                                    <i class="ph-fill ph-whatsapp-logo text-base"></i>
                                </span>
                                <span class="flex-1 text-sm font-medium text-dark-purple">WhatsApp</span>
                                <i class="ph ph-arrow-up-right text-gray-300 group-hover:text-dark-purple transition-colors text-sm"></i>
                            </a>
                            <a href="https://www.linkedin.com/company/dotnetcameroon" target="_blank"
                               class="flex items-center gap-3 p-4 hover:bg-gray-50/60 transition-colors group">
                                <span class="inline-flex items-center justify-center size-9 rounded-lg bg-gray-100 text-gray-700">
                                    <i class="ph-fill ph-linkedin-logo text-base"></i>
                                </span>
                                <span class="flex-1 text-sm font-medium text-dark-purple">LinkedIn</span>
                                <i class="ph ph-arrow-up-right text-gray-300 group-hover:text-dark-purple transition-colors text-sm"></i>
                            </a>
                            <a href="https://t.me/+cjXkPqigrZNkNDE0" target="_blank"
                               class="flex items-center gap-3 p-4 hover:bg-gray-50/60 transition-colors group">
                                <span class="inline-flex items-center justify-center size-9 rounded-lg bg-gray-100 text-gray-700">
                                    <i class="ph-fill ph-telegram-logo text-base"></i>
                                </span>
                                <span class="flex-1 text-sm font-medium text-dark-purple">Telegram</span>
                                <i class="ph ph-arrow-up-right text-gray-300 group-hover:text-dark-purple transition-colors text-sm"></i>
                            </a>
                            <a href="https://github.com/dotnetcameroon" target="_blank"
                               class="flex items-center gap-3 p-4 hover:bg-gray-50/60 transition-colors group">
                                <span class="inline-flex items-center justify-center size-9 rounded-lg bg-gray-100 text-gray-700">
                                    <i class="ph-fill ph-github-logo text-base"></i>
                                </span>
                                <span class="flex-1 text-sm font-medium text-dark-purple">GitHub</span>
                                <i class="ph ph-arrow-up-right text-gray-300 group-hover:text-dark-purple transition-colors text-sm"></i>
                            </a>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="bg-gray-50/50 border-t border-gray-100">
        <div class="container mx-auto px-6 lg:px-8 py-20 lg:py-24">
            <div class="max-w-3xl mx-auto">
                <div class="text-center">
                    <span class="eyebrow text-secondary justify-center">FAQ</span>
                    <h2 class="heading heading-1 mt-4">Frequently asked</h2>
                </div>

                <div class="mt-12 divide-y divide-gray-200/70 bg-white rounded-xl border border-gray-200/70">
                    @foreach (var faq in _faqs)
                    {
                        <details class="group p-6 [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                                <h3 class="heading font-semibold text-base text-dark-purple">@faq.Question</h3>
                                <i class="ph ph-plus text-base text-gray-400 group-open:hidden"></i>
                                <i class="ph ph-minus text-base text-gray-400 hidden group-open:inline"></i>
                            </summary>
                            <p class="text-gray-600 text-sm leading-relaxed mt-3">@faq.Answer</p>
                        </details>
                    }
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private IStringLocalizer? _sharedLocalizer;
    private IStringLocalizer SharedLocalizer => _sharedLocalizer ??= LocalizerFactory.Create("SharedResources", "app");

    private bool _submitted = false;
    private bool _isSubmitting = false;
    private string _errorMessage = "";

    private ContactFormData _formData = new();

    private record Faq(string Question, string Answer);

    private readonly Faq[] _faqs =
    [
        new("How can I become a member?",
            "Join our Discord or WhatsApp community to become an active member. Participate in events, contribute to projects, and engage with fellow developers."),
        new("Are your events free?",
            "Most of our community events are free. Some special workshops or conferences may have a registration fee to cover venue and material costs."),
        new("Can I propose a talk or workshop?",
            "Absolutely. We welcome proposals from community members — use the form above with \"Speaking opportunity\" as the subject."),
        new("How can my company sponsor .NET Cameroon?",
            "We offer several sponsorship packages. Contact us with \"Sponsorship\" as the subject and we'll send detailed information."),
    ];

    private async Task HandleSubmit()
    {
        _errorMessage = "";
        _isSubmitting = true;

        if (string.IsNullOrWhiteSpace(_formData.Name) ||
            string.IsNullOrWhiteSpace(_formData.Email) ||
            string.IsNullOrWhiteSpace(_formData.Subject) ||
            string.IsNullOrWhiteSpace(_formData.Message))
        {
            _errorMessage = "Please fill in all required fields.";
            _isSubmitting = false;
            return;
        }

        await Task.Delay(2000);

        _submitted = true;
        _isSubmitting = false;
    }

    private void ResetForm()
    {
        _formData = new ContactFormData();
        _submitted = false;
        _errorMessage = "";
    }

    private class ContactFormData
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Message { get; set; } = "";
    }
}
