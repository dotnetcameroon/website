@page "/"
@using app.business.Services
@using app.domain.Models.ProjectsAggregate
@using app.shared.Utilities
@using Microsoft.Extensions.Localization
@attribute [StreamRendering]
@inject IProjectService ProjectService
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory

<PageTitle>@SharedLocalizer["PageTitle_Home"]</PageTitle>
<HeadContent>
    <!-- Open Graph meta tags -->
    <meta property="og:title" content="@SharedLocalizer["Meta_Title"]">
    <meta property="og:description"
        content="@SharedLocalizer["Meta_Description"]">
    <meta property="og:image" content="https://dotnet.cm/assets/brand/logo.png">
    <meta property="og:url" content="https://dotnet.cm">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="@SharedLocalizer["Meta_Title"]">

    <!-- Twitter Card meta tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@SharedLocalizer["Meta_Title"]">
    <meta name="twitter:description"
        content="@SharedLocalizer["Meta_Description"]">
    <meta name="twitter:image" content="https://dotnet.cm/assets/brand/logo.png">
    <meta name="twitter:site" content="@@dotnetcameroon">

    <meta name="description"
        content="@SharedLocalizer["Meta_Description"]">
</HeadContent>

<div>
    <!-- Hero -->
    <section class="relative min-h-[92svh] bg-[url(/assets/featured/carousel-1.png)] bg-cover bg-center">
        <NavBar Type=@NavType.Transparent />
        <div class="absolute inset-0 z-10 bg-gradient-to-br from-dark-purple/95 via-dark-purple/75 to-dark-purple/40"></div>

        <div id="home" class="relative z-20 container mx-auto px-6 lg:px-8 pt-16 pb-24 lg:pt-24 lg:pb-32 min-h-[80svh] flex flex-col justify-center">
            <div class="max-w-3xl">
                <span class="eyebrow text-primary-accentuation">
                    <span class="relative flex size-1.5">
                        <span class="absolute inset-0 rounded-full bg-primary-accentuation opacity-60 animate-ping"></span>
                        <span class="relative size-1.5 rounded-full bg-primary-accentuation"></span>
                    </span>
                    @SharedLocalizer["Hero_Badge"]
                </span>
                <h1 class="text-white heading font-bold text-4xl sm:text-5xl lg:text-6xl leading-[1.05] tracking-tight mt-6">
                    @((MarkupString)SharedLocalizer["Hero_Title"].Value)
                </h1>
                <p class="text-white/75 text-base lg:text-lg leading-relaxed max-w-2xl mt-6">
                    @SharedLocalizer["Hero_Description"]
                </p>
                <div class="flex flex-wrap gap-3 mt-10">
                    <a data-enhance-nav="false" href="/about" class="btn btn-primary inline-flex items-center gap-2">
                        @SharedLocalizer["Hero_LearnMore"]
                        <i class="ph ph-arrow-right text-base"></i>
                    </a>
                    <a data-enhance-nav="false" href="https://chat.whatsapp.com/KlBkiJX85Y8KFS28tIm1UU" target="_blank"
                       class="btn bg-white/5 backdrop-blur-sm border border-white/20 text-white hover:bg-white/10 hover:border-white/30 inline-flex items-center gap-2">
                        <i class="ph-fill ph-whatsapp-logo text-xl"></i>
                        @SharedLocalizer["Hero_JoinUs"]
                    </a>
                </div>

                <!-- Quick stats — restrained, no big numbers shouting -->
                <dl class="hidden md:grid grid-cols-3 gap-8 mt-16 pt-8 border-t border-white/10 max-w-xl">
                    <div>
                        <dt class="text-white/50 text-[11px] uppercase tracking-widest">@SharedLocalizer["Membership_Stats_Members"]</dt>
                        <dd class="text-white heading font-semibold text-2xl tabular-nums mt-1.5">1 100+</dd>
                    </div>
                    <div>
                        <dt class="text-white/50 text-[11px] uppercase tracking-widest">@SharedLocalizer["Membership_Stats_Events"]</dt>
                        <dd class="text-white heading font-semibold text-2xl tabular-nums mt-1.5">60+</dd>
                    </div>
                    <div>
                        <dt class="text-white/50 text-[11px] uppercase tracking-widest">@((MarkupString)SharedLocalizer["Membership_Stats_Projects"].Value)</dt>
                        <dd class="text-white heading font-semibold text-2xl tabular-nums mt-1.5">6+</dd>
                    </div>
                </dl>
            </div>
        </div>
    </section>

    <!-- What we do -->
    <section class="bg-white">
        <div class="container mx-auto px-6 lg:px-8 py-24 lg:py-32">
            <div class="max-w-2xl mb-16">
                <span class="eyebrow text-primary">@SharedLocalizer["WhatWeDo_Badge"]</span>
                <h2 class="heading heading-1 mt-4">@SharedLocalizer["WhatWeDo_Title"]</h2>
                <p class="text-gray-600 mt-4 leading-relaxed">@SharedLocalizer["WhatWeDo_Description"]</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <ActivityCard ImageName="@Assets["/assets/activities/activity-1.jpg"]"
                              Title="@SharedLocalizer["Activity_LiveCoding_Title"]"
                              Description="@SharedLocalizer["Activity_LiveCoding_Description"]" />
                <ActivityCard ImageName="@Assets["/assets/activities/activity-2.jpeg"]"
                              Title="@SharedLocalizer["Activity_Conferences_Title"]"
                              Description="@SharedLocalizer["Activity_Conferences_Description"]" />
                <ActivityCard ImageName="@Assets["/assets/activities/activity-3.png"]"
                              Link="https://github.com/dotnetcameroon"
                              LinkText="@SharedLocalizer["Activity_VisitGitHub"]"
                              Title="@SharedLocalizer["Activity_OpenSource_Title"]"
                              Description="@SharedLocalizer["Activity_OpenSource_Description"]" />
            </div>
        </div>
    </section>

    <!-- Membership -->
    <section class="relative overflow-hidden bg-dark-purple">
        <div class="absolute inset-0 bg-[url(/assets/activities/membership.jpeg)] bg-cover bg-center opacity-25"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-dark-purple via-dark-purple/95 to-secondary/70"></div>
        <div class="relative container mx-auto px-6 lg:px-8 py-24 lg:py-32">
            <div class="max-w-3xl">
                <span class="eyebrow text-white/60">@SharedLocalizer["Membership_Badge"]</span>
                <h2 class="heading heading-1 text-white mt-4">@SharedLocalizer["Membership_Title"]</h2>
                <p class="text-white/75 leading-relaxed max-w-2xl mt-4">@SharedLocalizer["Membership_Description"]</p>

                <dl class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-10">
                    <div class="border-l border-white/15 pl-5">
                        <dt class="text-white/60 text-[11px] uppercase tracking-widest">@((MarkupString)SharedLocalizer["Membership_Stats_Members"].Value)</dt>
                        <dd class="text-white heading font-semibold text-3xl md:text-4xl tabular-nums mt-2">1 100+</dd>
                    </div>
                    <div class="border-l border-white/15 pl-5">
                        <dt class="text-white/60 text-[11px] uppercase tracking-widest">@((MarkupString)SharedLocalizer["Membership_Stats_Followers"].Value)</dt>
                        <dd class="text-white heading font-semibold text-3xl md:text-4xl tabular-nums mt-2">4 000+</dd>
                    </div>
                    <div class="border-l border-white/15 pl-5">
                        <dt class="text-white/60 text-[11px] uppercase tracking-widest">@SharedLocalizer["Membership_Stats_Events"]</dt>
                        <dd class="text-white heading font-semibold text-3xl md:text-4xl tabular-nums mt-2">60+</dd>
                    </div>
                    <div class="border-l border-white/15 pl-5">
                        <dt class="text-white/60 text-[11px] uppercase tracking-widest">@((MarkupString)SharedLocalizer["Membership_Stats_Projects"].Value)</dt>
                        <dd class="text-white heading font-semibold text-3xl md:text-4xl tabular-nums mt-2">6+</dd>
                    </div>
                </dl>

                <div class="mt-12 flex flex-wrap gap-3">
                    <a data-enhance-nav="false" href="https://chat.whatsapp.com/KlBkiJX85Y8KFS28tIm1UU" target="_blank"
                       class="btn bg-white text-dark-purple hover:bg-white/90 inline-flex items-center gap-2">
                        <i class="ph-fill ph-whatsapp-logo text-xl"></i>
                        @SharedLocalizer["Membership_BecomeMember"]
                    </a>
                    <a data-enhance-nav="false" href="/about"
                       class="btn bg-white/5 backdrop-blur-sm border border-white/20 text-white hover:bg-white/10 hover:border-white/30 inline-flex items-center gap-2">
                        @SharedLocalizer["Hero_LearnMore"]
                        <i class="ph ph-arrow-right text-base"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Partners -->
    <Partners />

    <!-- Projects -->
    @if (_projects.Length > 0)
    {
        <section class="bg-gray-50/50 border-t border-gray-100">
            <div class="container mx-auto px-6 lg:px-8 py-24 lg:py-32">
                <div class="max-w-2xl mb-16">
                    <span class="eyebrow text-secondary">@SharedLocalizer["Projects_Badge"]</span>
                    <h2 class="heading heading-1 mt-4">@SharedLocalizer["Projects_Title"]</h2>
                    <p class="text-gray-600 mt-4 leading-relaxed">@SharedLocalizer["Projects_Description"]</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    @foreach (var project in _projects)
                    {
                        <article class="group bg-white rounded-xl p-6 border border-gray-200/70 hover:border-gray-300 transition-colors flex flex-col">
                            <div class="flex-1">
                                <h3 class="heading font-semibold text-lg text-dark-purple group-hover:text-primary transition-colors">@project.Title</h3>
                                <p class="text-gray-600 line-clamp-3 text-sm mt-2.5 leading-relaxed">@project.Description</p>

                                <div class="flex flex-wrap gap-1.5 mt-5">
                                    @foreach (var tech in project.Technologies.Split(','))
                                    {
                                        <span class="text-[11px] px-2 py-0.5 rounded-md bg-gray-100 text-gray-700 font-medium tracking-tight">@tech.Trim()</span>
                                    }
                                </div>
                            </div>

                            <div class="flex items-center gap-4 mt-6 pt-5 border-t border-gray-100">
                                @if (!string.IsNullOrWhiteSpace(project.Github))
                                {
                                    <a href="@project.Github" title="@project.Title github" class="text-gray-400 hover:text-dark-purple transition-colors" target="_blank" aria-label="@($"{project.Title} GitHub")">
                                        <i class="ph-fill ph-github-logo text-lg"></i>
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(project.Website))
                                {
                                    <a href="@project.Website" title="@project.Title website" class="text-gray-400 hover:text-dark-purple transition-colors" target="_blank" aria-label="@($"{project.Title} website")">
                                        <i class="ph ph-globe text-lg"></i>
                                    </a>
                                }
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }
</div>

@code {
    private Project[] _projects = [];

    private IStringLocalizer? _sharedLocalizer;
    private IStringLocalizer SharedLocalizer => _sharedLocalizer ??= LocalizerFactory.Create("SharedResources", "app");

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _projects = await ProjectService.GetAllAsync();
    }
}
