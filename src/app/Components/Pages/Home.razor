@page "/"
@using app.business.Services
@using app.domain.Models.ProjectsAggregate
@using app.shared.Utilities
@using Microsoft.Extensions.Localization
@attribute [StreamRendering]
@inject IProjectService ProjectService
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory

<PageTitle>@SharedLocalizer["PageTitle_Home"]</PageTitle>
<HeadContent>
    <!-- Open Graph meta tags -->
    <meta property="og:title" content="@SharedLocalizer["Meta_Title"]">
    <meta property="og:description"
        content="@SharedLocalizer["Meta_Description"]">
    <meta property="og:image" content="https://dotnet.cm/assets/brand/logo.png">
    <meta property="og:url" content="https://dotnet.cm">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="@SharedLocalizer["Meta_Title"]">

    <!-- Twitter Card meta tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@SharedLocalizer["Meta_Title"]">
    <meta name="twitter:description"
        content="@SharedLocalizer["Meta_Description"]">
    <meta name="twitter:image" content="https://dotnet.cm/assets/brand/logo.png">
    <meta name="twitter:site" content="@@dotnetcameroon">

    <meta name="description"
        content="@SharedLocalizer["Meta_Description"]">
</HeadContent>

<div>
    <!-- Hero Section -->
    <section class="relative h-[100svh] bg-[url(/assets/featured/carousel-1.png)] bg-cover bg-center bg-fixed">
        <NavBar Type=@NavType.Transparent />
        <div class="absolute z-10 top-0 left-0 w-full h-full bg-gradient-to-r from-black/90 via-black/60 to-black/20"></div>
        <div class="absolute z-10 top-0 left-0 w-full h-full bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>

        <div id="home" class="relative z-20 h-full container mx-auto p-8">
            <div class="lg:w-2/3 h-full flex flex-col justify-center md:gap-6 gap-4 md:translate-y-[-40px] translate-y-[-30px]">
                <div class="flex justify-center md:justify-start">
                    <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full text-white text-sm font-semibold">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                        </span>
                        @SharedLocalizer["Hero_Badge"]
                    </span>
                </div>
                <h1 class="text-white text-center md:text-start heading font-bold text-5xl md:text-7xl md:leading-[80px]">
                    @((MarkupString)SharedLocalizer["Hero_Title"].Value)
                </h1>
                <p class="text-white/90 text-center md:text-start leading-[35px] md:text-lg max-w-2xl">@SharedLocalizer["Hero_Description"]</p>
                <div class="flex flex-wrap gap-4 justify-center md:justify-start">
                    <a data-enhance-nav="false" href="/about" class="btn btn-primary inline-flex items-center gap-2">
                        @SharedLocalizer["Hero_LearnMore"]
                        <i class="ph ph-arrow-right text-base"></i>
                    </a>
                    <a data-enhance-nav="false" href="https://chat.whatsapp.com/KlBkiJX85Y8KFS28tIm1UU" target="_blank" class="btn btn-outline-white inline-flex items-center gap-2">
                        <i class="ph-fill ph-whatsapp-logo text-xl"></i>
                        @SharedLocalizer["Hero_JoinUs"]
                    </a>
                </div>

                <!-- Quick Stats -->
                <div class="hidden md:flex gap-8 mt-8 pt-8 border-t border-white/20 max-w-2xl">
                    <div>
                        <div class="text-white heading font-bold text-3xl">1 100+</div>
                        <div class="text-white/70 text-sm">@SharedLocalizer["Membership_Stats_Members"]</div>
                    </div>
                    <div>
                        <div class="text-white heading font-bold text-3xl">60+</div>
                        <div class="text-white/70 text-sm">@SharedLocalizer["Membership_Stats_Events"]</div>
                    </div>
                    <div>
                        <div class="text-white heading font-bold text-3xl">6+</div>
                        <div class="text-white/70 text-sm">@((MarkupString)SharedLocalizer["Membership_Stats_Projects"].Value)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="hidden md:block absolute bottom-8 left-1/2 -translate-x-1/2 z-20">
            <div class="flex flex-col items-center gap-2 text-white/70 animate-bounce">
                <span class="text-xs uppercase tracking-widest">@SharedLocalizer["Hero_Scroll"]</span>
                <i class="ph ph-caret-down text-base"></i>
            </div>
        </div>
    </section>

    <!-- What we do -->
    <section class="bg-gradient-to-b from-white to-gray-50">
        <div class="section container mx-auto">
            <div class="text-center max-w-2xl mx-auto mb-14">
                <span class="inline-block px-4 py-1 bg-primary/10 text-primary rounded-full text-sm font-semibold mb-4">
                    @SharedLocalizer["WhatWeDo_Badge"]
                </span>
                <h2 class="heading heading-1">@SharedLocalizer["WhatWeDo_Title"]</h2>
                <p class="text-gray-600">@SharedLocalizer["WhatWeDo_Description"]</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
                <ActivityCard ImageName="@Assets["/assets/activities/activity-1.jpg"]" Title="@SharedLocalizer["Activity_LiveCoding_Title"]"
                    Description="@SharedLocalizer["Activity_LiveCoding_Description"]" />
                <ActivityCard ImageName="@Assets["/assets/activities/activity-2.jpeg"]" Title="@SharedLocalizer["Activity_Conferences_Title"]"
                    Description="@SharedLocalizer["Activity_Conferences_Description"]" />
                <ActivityCard ImageName="@Assets["/assets/activities/activity-3.png"]"
                    Link="https://github.com/dotnetcameroon" LinkText="@SharedLocalizer["Activity_VisitGitHub"]" Title="@SharedLocalizer["Activity_OpenSource_Title"]"
                    Description="@SharedLocalizer["Activity_OpenSource_Description"]" />
            </div>
        </div>
    </section>

    <!-- About / Membership -->
    <section class="relative bg-[url(/assets/activities/membership.jpeg)] bg-cover bg-center bg-no-repeat">
        <div class="absolute z-10 top-0 left-0 w-full h-full bg-gradient-to-r from-secondary via-secondary/90 to-secondary/60"></div>
        <div class="relative z-20 section container mx-auto">
            <div class="max-w-3xl">
                <span class="inline-block px-4 py-1 bg-white/15 backdrop-blur text-white rounded-full text-sm font-semibold mb-4 border border-white/20">
                    @SharedLocalizer["Membership_Badge"]
                </span>
                <h2 class="heading heading-1 text-white">@SharedLocalizer["Membership_Title"]</h2>
                <p class="md:w-4/5 text-white/90 leading-relaxed">@SharedLocalizer["Membership_Description"]</p>

                <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-6">
                    <div class="bg-white/10 backdrop-blur rounded-2xl p-5 border border-white/20">
                        <div class="heading text-white font-bold text-3xl md:text-4xl">1 100+</div>
                        <p class="text-white/80 text-sm mt-1">@((MarkupString)SharedLocalizer["Membership_Stats_Members"].Value)</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur rounded-2xl p-5 border border-white/20">
                        <div class="heading text-white font-bold text-3xl md:text-4xl">4 000+</div>
                        <p class="text-white/80 text-sm mt-1">@((MarkupString)SharedLocalizer["Membership_Stats_Followers"].Value)</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur rounded-2xl p-5 border border-white/20">
                        <div class="heading text-white font-bold text-3xl md:text-4xl">60+</div>
                        <p class="text-white/80 text-sm mt-1">@SharedLocalizer["Membership_Stats_Events"]</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur rounded-2xl p-5 border border-white/20">
                        <div class="heading text-white font-bold text-3xl md:text-4xl">6+</div>
                        <p class="text-white/80 text-sm mt-1">@((MarkupString)SharedLocalizer["Membership_Stats_Projects"].Value)</p>
                    </div>
                </div>

                <div class="mt-8 flex flex-wrap gap-4">
                    <a data-enhance-nav="false" href="https://chat.whatsapp.com/KlBkiJX85Y8KFS28tIm1UU" target="_blank" class="btn btn-outline-white inline-flex items-center gap-2">
                        <i class="ph-fill ph-whatsapp-logo text-xl"></i>
                        @SharedLocalizer["Membership_BecomeMember"]
                    </a>
                    <a data-enhance-nav="false" href="/about" class="btn bg-white/10 backdrop-blur border border-white/20 text-white hover:bg-white/20 inline-flex items-center gap-2">
                        @SharedLocalizer["Hero_LearnMore"]
                        <i class="ph ph-arrow-right text-base"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Partners -->
    <Partners />

    <!-- Projects -->
    @if(_projects.Length > 0)
    {
        <section class="bg-gray-50">
            <div class="section container mx-auto">
                <div class="text-center max-w-2xl mx-auto mb-12">
                    <span class="inline-block px-4 py-1 bg-secondary/10 text-secondary rounded-full text-sm font-semibold mb-4">
                        @SharedLocalizer["Projects_Badge"]
                    </span>
                    <h2 class="heading heading-1">@SharedLocalizer["Projects_Title"]</h2>
                    <p class="text-gray-600">@SharedLocalizer["Projects_Description"]</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var project in _projects)
                    {
                        <div class="group bg-white rounded-2xl p-6 border border-gray-100 hover:border-primary/30 hover:shadow-xl transition-all duration-300 flex flex-col">
                            <div class="flex-1">
                                <h3 class="heading heading-5 text-dark-purple group-hover:text-primary transition-colors">@project.Title</h3>
                                <p class="text-gray-600 line-clamp-3 text-sm mt-2 mb-4">@project.Description</p>

                                <div class="flex flex-wrap gap-2">
                                    @foreach (var tech in project.Technologies.Split(','))
                                    {
                                        <span class="text-xs px-2 py-1 rounded-md bg-secondary/10 text-secondary font-semibold">#@tech.Trim()</span>
                                    }
                                </div>
                            </div>

                            <div class="flex flex-wrap gap-3 mt-4 pt-4 border-t border-gray-100">
                                @if(!string.IsNullOrWhiteSpace(project.Github))
                                {
                                    <a href="@project.Github" title="@project.Title github" class="text-gray-500 hover:text-primary transition-all" target="_blank" aria-label="@($"{project.Title} GitHub")">
                                        <i class="ph-fill ph-github-logo text-xl"></i>
                                    </a>
                                }
                                @if(!string.IsNullOrWhiteSpace(project.Website))
                                {
                                    <a href="@project.Website" title="@project.Title website" class="text-gray-500 hover:text-primary transition-all" target="_blank" aria-label="@($"{project.Title} website")">
                                        <i class="ph ph-globe text-xl"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</div>

@code {
    private Project[] _projects = [];

    private IStringLocalizer? _sharedLocalizer;
    private IStringLocalizer SharedLocalizer => _sharedLocalizer ??= LocalizerFactory.Create("SharedResources", "app");

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _projects = await ProjectService.GetAllAsync();
    }
}
