@page "/about"
@using Microsoft.Extensions.Localization
@attribute [StreamRendering]
@inject IStringLocalizerFactory LocalizerFactory

<PageTitle>@SharedLocalizer["About_PageTitle"]</PageTitle>
<HeadContent>
    <meta name="description" content="@SharedLocalizer["About_MetaDescription"]">
    <meta property="og:title" content="@SharedLocalizer["About_PageTitle"]">
    <meta property="og:description" content="@SharedLocalizer["About_MetaDescription"]">
    <meta property="og:image" content="https://dotnet.cm/assets/brand/logo.png">
    <meta property="og:url" content="https://dotnet.cm/about">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@SharedLocalizer["About_PageTitle"]">
    <meta name="twitter:description" content="@SharedLocalizer["About_MetaDescription"]">
</HeadContent>

<div>
    <NavBar />

    <!-- Hero -->
    <section class="relative bg-dark-purple overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-dark-purple via-secondary/40 to-dark-purple"></div>
        <div class="relative container mx-auto px-6 lg:px-8 py-24 lg:py-32">
            <div class="max-w-3xl">
                <span class="eyebrow text-white/60">@SharedLocalizer["About_Hero_Badge"]</span>
                <h1 class="text-white heading font-bold text-4xl sm:text-5xl lg:text-6xl leading-[1.05] tracking-tight mt-6">
                    @((MarkupString)SharedLocalizer["About_Hero_Title"].Value)
                </h1>
                <p class="text-white/75 text-base lg:text-lg leading-relaxed max-w-2xl mt-6">
                    @SharedLocalizer["About_Hero_Subtitle"]
                </p>
            </div>
        </div>
    </section>

    <!-- Our Story -->
    <section class="bg-white">
        <div class="container mx-auto px-6 lg:px-8 py-24 lg:py-32">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                <div>
                    <img src="@Assets["/assets/activities/activity-2.jpeg"]"
                         alt=".NET Cameroon community event"
                         class="rounded-xl w-full object-cover aspect-[4/3] border border-gray-200/70" />
                </div>
                <div>
                    <span class="eyebrow text-primary">@SharedLocalizer["About_Story_Badge"]</span>
                    <h2 class="heading heading-1 mt-4">@SharedLocalizer["About_Story_Title"]</h2>
                    <div class="space-y-4 text-gray-700 leading-relaxed mt-6">
                        <p>@((MarkupString)SharedLocalizer["About_Story_Paragraph1"].Value)</p>
                        <p>@((MarkupString)SharedLocalizer["About_Story_Paragraph2"].Value)</p>
                        <p>@SharedLocalizer["About_Story_Paragraph3"]</p>
                    </div>

                    <dl class="grid grid-cols-3 gap-6 mt-10 pt-8 border-t border-gray-100">
                        <div>
                            <dt class="text-gray-500 text-[11px] uppercase tracking-widest">@SharedLocalizer["Membership_Stats_Members"]</dt>
                            <dd class="heading font-semibold text-2xl text-dark-purple tabular-nums mt-2">1 100+</dd>
                        </div>
                        <div>
                            <dt class="text-gray-500 text-[11px] uppercase tracking-widest">@SharedLocalizer["Membership_Stats_Events"]</dt>
                            <dd class="heading font-semibold text-2xl text-dark-purple tabular-nums mt-2">60+</dd>
                        </div>
                        <div>
                            <dt class="text-gray-500 text-[11px] uppercase tracking-widest">@SharedLocalizer["About_Stats_Founded"]</dt>
                            <dd class="heading font-semibold text-2xl text-dark-purple tabular-nums mt-2">2023</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission -->
    <section class="bg-gray-50/50 border-t border-gray-100">
        <div class="container mx-auto px-6 lg:px-8 py-24 lg:py-32">
            <div class="max-w-2xl mb-16">
                <span class="eyebrow text-secondary">@SharedLocalizer["About_Mission_Badge"]</span>
                <h2 class="heading heading-1 mt-4">@SharedLocalizer["About_Mission_Title"]</h2>
                <p class="text-gray-600 mt-4 leading-relaxed">@SharedLocalizer["About_Mission_Intro"]</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                @* iconClass, color, title, description pattern repeated below *@
                <article class="group bg-white p-7 rounded-xl border border-gray-200/70 hover:border-gray-300 transition-colors">
                    <div class="inline-flex items-center justify-center size-11 rounded-lg bg-primary/10 mb-5">
                        <i class="ph-duotone ph-megaphone text-2xl text-primary"></i>
                    </div>
                    <h3 class="heading font-semibold text-lg text-dark-purple">@SharedLocalizer["About_Mission_1_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2.5">@SharedLocalizer["About_Mission_1_Description"]</p>
                </article>

                <article class="group bg-white p-7 rounded-xl border border-gray-200/70 hover:border-gray-300 transition-colors">
                    <div class="inline-flex items-center justify-center size-11 rounded-lg bg-secondary/10 mb-5">
                        <i class="ph-duotone ph-hand-heart text-2xl text-secondary"></i>
                    </div>
                    <h3 class="heading font-semibold text-lg text-dark-purple">@SharedLocalizer["About_Mission_2_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2.5">@SharedLocalizer["About_Mission_2_Description"]</p>
                </article>

                <article class="group bg-white p-7 rounded-xl border border-gray-200/70 hover:border-gray-300 transition-colors">
                    <div class="inline-flex items-center justify-center size-11 rounded-lg bg-tertiary/10 mb-5">
                        <i class="ph-duotone ph-lightbulb text-2xl text-tertiary"></i>
                    </div>
                    <h3 class="heading font-semibold text-lg text-dark-purple">@SharedLocalizer["About_Mission_3_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2.5">@SharedLocalizer["About_Mission_3_Description"]</p>
                </article>

                <article class="group bg-white p-7 rounded-xl border border-gray-200/70 hover:border-gray-300 transition-colors">
                    <div class="inline-flex items-center justify-center size-11 rounded-lg bg-primary/10 mb-5">
                        <i class="ph-duotone ph-git-branch text-2xl text-primary"></i>
                    </div>
                    <h3 class="heading font-semibold text-lg text-dark-purple">@SharedLocalizer["About_Mission_4_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2.5">@SharedLocalizer["About_Mission_4_Description"]</p>
                </article>

                <article class="group bg-white p-7 rounded-xl border border-gray-200/70 hover:border-gray-300 transition-colors">
                    <div class="inline-flex items-center justify-center size-11 rounded-lg bg-secondary/10 mb-5">
                        <i class="ph-duotone ph-lifebuoy text-2xl text-secondary"></i>
                    </div>
                    <h3 class="heading font-semibold text-lg text-dark-purple">@SharedLocalizer["About_Mission_5_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2.5">@SharedLocalizer["About_Mission_5_Description"]</p>
                </article>

                <article class="group bg-white p-7 rounded-xl border border-gray-200/70 hover:border-gray-300 transition-colors">
                    <div class="inline-flex items-center justify-center size-11 rounded-lg bg-tertiary/10 mb-5">
                        <i class="ph-duotone ph-calendar-check text-2xl text-tertiary"></i>
                    </div>
                    <h3 class="heading font-semibold text-lg text-dark-purple">@SharedLocalizer["About_Mission_6_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2.5">@SharedLocalizer["About_Mission_6_Description"]</p>
                </article>
            </div>
        </div>
    </section>

    <!-- Values -->
    <section class="bg-white">
        <div class="container mx-auto px-6 lg:px-8 py-24 lg:py-32">
            <div class="max-w-2xl mb-16">
                <span class="eyebrow text-tertiary">@SharedLocalizer["About_Values_Badge"]</span>
                <h2 class="heading heading-1 mt-4">@SharedLocalizer["About_Values_Title"]</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12">
                <div>
                    <div class="inline-flex items-center justify-center size-12 rounded-xl bg-primary/10 mb-5">
                        <i class="ph-fill ph-heart text-2xl text-primary"></i>
                    </div>
                    <h3 class="heading font-semibold text-base text-dark-purple">@SharedLocalizer["About_Value_Passion_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2">@SharedLocalizer["About_Value_Passion_Description"]</p>
                </div>
                <div>
                    <div class="inline-flex items-center justify-center size-12 rounded-xl bg-secondary/10 mb-5">
                        <i class="ph-fill ph-handshake text-2xl text-secondary"></i>
                    </div>
                    <h3 class="heading font-semibold text-base text-dark-purple">@SharedLocalizer["About_Value_Collaboration_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2">@SharedLocalizer["About_Value_Collaboration_Description"]</p>
                </div>
                <div>
                    <div class="inline-flex items-center justify-center size-12 rounded-xl bg-tertiary/10 mb-5">
                        <i class="ph-fill ph-graduation-cap text-2xl text-tertiary"></i>
                    </div>
                    <h3 class="heading font-semibold text-base text-dark-purple">@SharedLocalizer["About_Value_Learning_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2">@SharedLocalizer["About_Value_Learning_Description"]</p>
                </div>
                <div>
                    <div class="inline-flex items-center justify-center size-12 rounded-xl bg-primary/10 mb-5">
                        <i class="ph-fill ph-globe-hemisphere-west text-2xl text-primary"></i>
                    </div>
                    <h3 class="heading font-semibold text-base text-dark-purple">@SharedLocalizer["About_Value_Impact_Title"]</h3>
                    <p class="text-gray-600 text-sm leading-relaxed mt-2">@SharedLocalizer["About_Value_Impact_Description"]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Founders -->
    <section class="bg-gray-50/50 border-t border-gray-100">
        <div class="container mx-auto px-6 lg:px-8 py-24 lg:py-32">
            <div class="max-w-2xl mb-16">
                <span class="eyebrow text-primary">@SharedLocalizer["About_Founders_Badge"]</span>
                <h2 class="heading heading-1 mt-4">@SharedLocalizer["About_Founders_Title"]</h2>
                <p class="text-gray-600 mt-4 leading-relaxed">@SharedLocalizer["About_Founders_Intro"]</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl">
                <!-- Djoufson Che -->
                <article class="group bg-white rounded-xl border border-gray-200/70 hover:border-gray-300 overflow-hidden transition-colors">
                    <div class="aspect-square overflow-hidden bg-gray-100">
                        <img src="@Assets["/assets/team/djoufson-che.png"]" alt="Djoufson Che"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
                    </div>
                    <div class="p-6">
                        <h3 class="heading font-semibold text-lg text-dark-purple">Djoufson Che</h3>
                        <p class="eyebrow text-primary mt-3">@SharedLocalizer["About_Founder_Djoufson_Role"]</p>
                        <p class="text-gray-600 text-sm leading-relaxed mt-4">@SharedLocalizer["About_Founder_Djoufson_Bio"]</p>
                        <a href="https://djoufson.com" target="_blank" rel="noopener"
                           class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-secondary hover:text-secondary-accentuation transition-colors">
                            djoufson.com
                            <i class="ph ph-arrow-up-right text-sm"></i>
                        </a>
                    </div>
                </article>

                <!-- Jaures Beinjamin -->
                <article class="group bg-white rounded-xl border border-gray-200/70 hover:border-gray-300 overflow-hidden transition-colors">
                    <div class="aspect-square overflow-hidden bg-gray-100">
                        <img src="@Assets["/assets/team/jaures-fotsing.png"]" alt="Jaures Beinjamin"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
                    </div>
                    <div class="p-6">
                        <h3 class="heading font-semibold text-lg text-dark-purple">Jaures Beinjamin</h3>
                        <p class="eyebrow text-secondary mt-3">@SharedLocalizer["About_Founder_Jaures_Role"]</p>
                        <p class="text-gray-600 text-sm leading-relaxed mt-4">@SharedLocalizer["About_Founder_Jaures_Bio"]</p>
                        <a href="https://www.jaures.me" target="_blank" rel="noopener"
                           class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-secondary hover:text-secondary-accentuation transition-colors">
                            jaures.me
                            <i class="ph ph-arrow-up-right text-sm"></i>
                        </a>
                    </div>
                </article>

                <!-- Septime Lowe -->
                <article class="group bg-white rounded-xl border border-gray-200/70 hover:border-gray-300 overflow-hidden transition-colors">
                    <div class="aspect-square overflow-hidden bg-gray-100">
                        <img src="@Assets["/assets/team/septime.jpeg"]" alt="Septime Lowe"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
                    </div>
                    <div class="p-6">
                        <h3 class="heading font-semibold text-lg text-dark-purple">Septime Lowe</h3>
                        <p class="eyebrow text-tertiary mt-3">@SharedLocalizer["About_Founder_Septime_Role"]</p>
                        <p class="text-gray-600 text-sm leading-relaxed mt-4">@SharedLocalizer["About_Founder_Septime_Bio"]</p>
                        <a href="https://www.linkedin.com/in/septime-lowe-b59513136/" target="_blank" rel="noopener"
                           class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-secondary hover:text-secondary-accentuation transition-colors">
                            <i class="ph-fill ph-linkedin-logo text-sm"></i>
                            LinkedIn
                            <i class="ph ph-arrow-up-right text-sm"></i>
                        </a>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- Partners -->
    <Partners />

    <!-- CTA -->
    <section class="relative bg-dark-purple overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/30 via-dark-purple to-secondary/40"></div>
        <div class="relative container mx-auto px-6 lg:px-8 py-20 lg:py-24">
            <div class="max-w-3xl">
                <h2 class="heading text-white font-bold text-3xl md:text-5xl tracking-tight leading-tight">
                    @SharedLocalizer["About_CTA_Title"]
                </h2>
                <p class="text-white/75 text-base lg:text-lg leading-relaxed mt-5 max-w-2xl">
                    @SharedLocalizer["About_CTA_Description"]
                </p>
                <div class="flex flex-wrap gap-3 mt-10">
                    <a data-enhance-nav="false" href="https://chat.whatsapp.com/KlBkiJX85Y8KFS28tIm1UU" target="_blank"
                       class="btn bg-white text-dark-purple hover:bg-white/90 inline-flex items-center gap-2">
                        <i class="ph-fill ph-whatsapp-logo text-xl"></i>
                        @SharedLocalizer["About_CTA_Join"]
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private IStringLocalizer? _sharedLocalizer;
    private IStringLocalizer SharedLocalizer => _sharedLocalizer ??= LocalizerFactory.Create("SharedResources", "app");
}
