@page "/errors"
<PageTitle>An unexpected error has occurred</PageTitle>
<NavBar />

<div>
    <section class="container mx-auto px-6 lg:px-8 py-24 lg:py-32">
        <div class="max-w-xl mx-auto text-center">
            <span class="eyebrow text-tertiary justify-center">Error</span>
            <h1 class="heading font-bold text-3xl lg:text-4xl text-dark-purple tracking-tight leading-tight mt-4">
                Something went wrong.
            </h1>
            <p class="text-gray-600 leading-relaxed mt-4">
                An unexpected error occurred and we're looking into it. Please try again later, or let us know if the problem persists.
            </p>
            <div class="flex flex-wrap justify-center gap-3 mt-8">
                <a data-enhance-nav="false" href="/" class="btn btn-primary inline-flex items-center gap-2">
                    <i class="ph ph-arrow-left text-base"></i>
                    Back to home
                </a>
                <a data-enhance-nav="false" href="/contact" class="btn btn-outline inline-flex items-center gap-2">
                    Report an issue
                    <i class="ph ph-arrow-up-right text-base"></i>
                </a>
            </div>
        </div>
    </section>
</div>
